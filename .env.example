# ── LLM Provider (Google Gemini) ──────────────────────────────
# Obtain from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Model to use (default: gemini-3.5-flash — fast and cost-effective)
GEMINI_MODEL=gemini-3.5-flash

# ── Server ────────────────────────────────────────────────────
PORT=3001

# Allowed origins for CORS (comma-separated). Lock this in production.
CORS_ORIGIN=http://localhost:5173

# ── Database ──────────────────────────────────────────────────
# SQLite file path (relative to server root)
DATABASE_PATH=./spur_chat.db

# ── Safety Limits ─────────────────────────────────────────────
# Max tokens the LLM may generate per reply
MAX_RESPONSE_TOKENS=512

# Max conversation history messages sent to the LLM (keeps cost low)
MAX_HISTORY_MESSAGES=20

# Max characters allowed in a single user message
MAX_MESSAGE_LENGTH=2000

# Rate limiting: max requests per window per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
